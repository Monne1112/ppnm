set terminal png
set output "recover.png"

set xlabel "x"
set ylabel "y"

plot "recover.data" using 1:(abs($3) < 1e-6 ? $2 : 1/0) with point title "missing points", \
     "recover.data" using 1:3 with linespoint title "corrupted", \
     "recover.data" using 1:(abs($3) < 1e-6 ? $2 : 1/0) with points title "recovered" pointtype 6 pointsize 3